{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Flask",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/app.py",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "Running on (http?://127\\.0\\.0\\.1:5000)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    }
  ]
}